# SYNTAX TEST "Packages/Crontab/Anacrontab.sublime-syntax"

# environment variables
SHELL=/bin/sh
PATH=/sbin:/bin:/usr/sbin:/usr/bin
MAILTO=root
RANDOM_DELAY=30
#^^^^^^^^^^^ variable.other.readwrite.crontab
#           ^ keyword.operator.assignment.crontab
#            ^^ meta.string.crontab string.unquoted.crontab

# Anacron jobs will start between 6am and 8am.
START_HOURS_RANGE=6-8

# delay will be 5 minutes + RANDOM_DELAY for cron.daily
1           5   cron.daily          nice run-parts /etc/cron.daily
7           0   cron.weekly         nice run-parts /etc/cron.weekly
#           ^ meta.number.integer.decimal.anacron constant.numeric.value.anacron
#               ^^^^^^^^^^^ entity.name.function.anacron
#                                   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.shell.bash.crontab
@monthly    0   cron.monthly        nice run-parts /etc/cron.monthly
#^^^^^^^ constant.language.schedule.crontab
#           ^ meta.number.integer.decimal.anacron constant.numeric.value.anacron
#               ^^^^^^^^^^^^ entity.name.function.anacron
#                                   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ source.shell.bash.crontab
